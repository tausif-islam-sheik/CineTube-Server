model Like {
  id        String @id @default(uuid())

  userId    String @map("user_id")
  reviewId  String @map("review_id")

  user      User   @relation(fields: [userId], references: [id])
  review    Review @relation(fields: [reviewId], references: [id])

  @@unique([userId, reviewId])
  @@index([reviewId])
  @@map("likes")
}